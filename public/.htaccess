<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # If the requested path is a real file or directory, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Otherwise, route all other traffic to index.html
  RewriteRule ^ index.html [L]
</IfModule>
